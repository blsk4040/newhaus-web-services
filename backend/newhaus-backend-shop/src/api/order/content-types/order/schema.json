{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "customerName": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "company": {
      "type": "string"
    },
    "deliveryAddress": {
      "type": "text",
      "required": true
    },
    "city": {
      "type": "string",
      "required": true
    },
    "province": {
      "type": "string",
      "required": true
    },
    "country": {
      "type": "string",
      "required": true
    },
    "shippingMethod": {
      "type": "string",
      "required": true
    },
    "subtotal": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "shippingAmount": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "total": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "zohoAccountId": {
      "type": "string"
    },
    "zohoContactId": {
      "type": "string"
    },
    "zohoSalesOrderId": {
      "type": "string"
    },
    "items": {
      "type": "text",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "orderStatus": {
      "type": "string",
      "required": true
    }
  }
